@model TokoSaya.Models.Category

@{
    ViewData["Title"] = "Edit Category";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-warning text-dark py-4 px-4 border-0">
                    <h2 class="fw-bold mb-1">Edit Kategori</h2>
                    <p class="mb-0 text-dark-emphasis">Perbarui data kategori sesuai kebutuhan</p>
                </div>

                <div class="card-body p-4">
                    <form method="post">
                        <input asp-for="Id" type="hidden" />
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control form-control-lg rounded-3" placeholder="Masukkan nama kategori" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-warning btn-lg rounded-pill px-4 fw-semibold text-dark">
                                Update
                            </button>
                            <a asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill px-4 fw-semibold">
                                Kembali
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}