@model TokoSaya.ViewModels.LoginVM

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .auth-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background:
            radial-gradient(circle at top left, rgba(99, 102, 241, 0.18), transparent 30%),
            radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.18), transparent 30%),
            linear-gradient(135deg, #f8fafc, #e2e8f0);
        padding: 32px 16px;
    }

    .auth-card {
        width: 100%;
        max-width: 430px;
        background: rgba(255, 255, 255, 0.78);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(15, 23, 42, 0.12);
        padding: 36px 30px;
    }

    .auth-badge {
        width: 58px;
        height: 58px;
        margin: 0 auto 18px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #4f46e5, #2563eb);
        color: white;
        font-size: 24px;
        font-weight: 700;
        box-shadow: 0 10px 30px rgba(79, 70, 229, 0.35);
    }

    .auth-title {
        text-align: center;
        font-weight: 700;
        font-size: 2rem;
        color: #0f172a;
        margin-bottom: 6px;
    }

    .auth-subtitle {
        text-align: center;
        color: #64748b;
        font-size: 0.95rem;
        margin-bottom: 28px;
    }

    .form-label {
        font-weight: 600;
        color: #334155;
        margin-bottom: 8px;
    }

    .modern-input {
        border: 1px solid #dbe2ea;
        border-radius: 14px;
        padding: 14px 16px;
        font-size: 0.96rem;
        background: rgba(255,255,255,0.9);
        transition: all 0.25s ease;
        box-shadow: none;
    }

    .modern-input:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.12);
    }

    .modern-check {
        width: 18px;
        height: 18px;
        margin-top: 0.2rem;
        border-radius: 6px;
    }

    .modern-btn {
        width: 100%;
        border: none;
        border-radius: 14px;
        padding: 14px;
        font-weight: 600;
        font-size: 1rem;
        color: white;
        background: linear-gradient(135deg, #4f46e5, #2563eb);
        transition: all 0.25s ease;
        box-shadow: 0 14px 28px rgba(37, 99, 235, 0.22);
    }

    .modern-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 18px 34px rgba(37, 99, 235, 0.28);
        color: white;
    }

    .auth-link {
        text-align: center;
        margin-top: 20px;
        color: #64748b;
        font-size: 0.95rem;
    }

    .auth-link a {
        color: #2563eb;
        font-weight: 600;
        text-decoration: none;
    }

    .auth-link a:hover {
        text-decoration: underline;
    }

    .validation-summary-errors ul {
        margin-bottom: 0;
        padding-left: 1rem;
    }
</style>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-badge">L</div>

        <h1 class="auth-title">Welcome Back</h1>
        <p class="auth-subtitle">Masuk ke akun Anda untuk melanjutkan</p>

        <form asp-action="Login" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control modern-input" placeholder="Masukkan email Anda" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-control modern-input" placeholder="Masukkan password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-check d-flex align-items-center gap-2 mb-4">
                <input asp-for="RememberMe" class="form-check-input modern-check" />
                <label asp-for="RememberMe" class="form-check-label text-secondary">Remember me</label>
            </div>

            <button type="submit" class="modern-btn">Login</button>

            <div class="auth-link">
                Belum punya akun?
                <a asp-controller="Account" asp-action="Register">Daftar sekarang</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}