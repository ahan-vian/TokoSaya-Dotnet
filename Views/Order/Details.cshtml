@model TokoSaya.ViewModels.OrderVM
@using TokoSaya.Utility
@{
    ViewData["Title"] = "Detail Pesanan";
}

<div class="container py-5">
    <div class="row">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-primary text-white py-3 px-4">
                    <h4 class="fw-bold">Detail Pengiriman</h4>
                </div>
                <div class="card-body p-4">
                    <p><strong>Nama:</strong> @Model.OrderHeader.Name</p>
                    <p><strong>Nomor Telepon:</strong> @Model.OrderHeader.PhoneNumber</p>
                    <p><strong>Alamat:</strong> @Model.OrderHeader.StreetAddress</p>
                    <p><strong>Tanggal Pesanan:</strong> @Model.OrderHeader.OrderDate.ToShortDateString()</p>
                    @if (!string.IsNullOrEmpty(Model.OrderHeader.OrderNote))
                    {
                        <div class="mt-3 p-3 bg-warning bg-opacity-10 border border-warning rounded-3 shadow-sm">
                            <p class="mb-1 fw-bold text-dark"><i class="bi bi-chat-left-text"></i> Catatan Pembeli:</p>
                            <p class="mb-0 text-muted fst-italic">"@Model.OrderHeader.OrderNote"</p>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.OrderHeader.PaymentReceiptUrl))
                    {
                        <div class="mt-4 pt-3 border-top">
                            <p class="fw-bold"><i class="bi bi-image"></i> Bukti Pembayaran:</p>
                            <div class="text-center bg-light p-2 rounded-3 border">
                                <a href="@Model.OrderHeader.PaymentReceiptUrl" target="_blank">
                                    <img src="@Model.OrderHeader.PaymentReceiptUrl" class="img-fluid rounded-3 shadow-sm"
                                         style="max-height: 250px; cursor: zoom-in;" alt="Bukti Transfer" />
                                </a>
                                <small class="text-muted d-block mt-2">Klik gambar untuk memperbesar</small>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mt-4 pt-3 border-top">
                            <div class="alert alert-warning py-2 small mb-0">
                                <i class="bi bi-exclamation-triangle"></i> Belum ada bukti pembayaran diunggah.
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-info text-white py-3 px-4">
                    <h4 class="fw-bold">Rincian Pesanan</h4>
                </div>
                <div class="card-body p-4">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Nama Produk</th>
                                <th>Harga</th>
                                <th>Jumlah</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderDetail)
                            {
                                <tr>
                                    <td>@(item.Product?.Name)</td>
                                    <td>Rp @(item.Price.ToString("N0"))</td>
                                    <td>@(item.Count)</td>
                                    <td>Rp @((item.Count * item.Price).ToString("N0"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="d-flex justify-content-between">
                        <h5 class="fw-bold">Total Harga:</h5>
                        <h5 class="fw-bold text-success">Rp @Model.OrderHeader.OrderTotal.ToString("N0")</h5>
                    </div>
                    <hr class="my-4" />
                    
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Status:</h5>
                        <span class="badge bg-dark fs-6 px-3 py-2 rounded-pill">@Model.OrderHeader.OrderStatus</span>
                    </div>

                    @if (User.IsInRole(SD.Role_Admin))
                    {
                        @if (!string.IsNullOrEmpty(Model.OrderHeader.PaymentReceiptUrl) && Model.OrderHeader.PaymentStatus != SD.PaymentStatusApproved)
                        {
                            <form asp-controller="Order" asp-action="Pembayaran" method="post" class="mb-3">
                                <input type="hidden" name="id" value="@Model.OrderHeader.Id" />
                                <button type="submit" class="btn btn-warning w-100 rounded-pill fw-bold py-2 shadow-sm">
                                    <i class="bi bi-check-circle"></i> Verifikasi Pembayaran (Set Lunas)
                                </button>
                            </form>
                        }

                        @if (Model.OrderHeader.OrderStatus == SD.StatusPending)
                        {
                            <form asp-controller="Order" asp-action="StartProcessing" method="post" class="mb-2">
                                <input type="hidden" name="id" value="@Model.OrderHeader.Id" />
                                <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold py-2 shadow-sm">
                                    Mulai Proses Pesanan
                                </button>
                            </form>
                        }

                        @if (Model.OrderHeader.OrderStatus == SD.StatusInProcess)
                        {
                            <form asp-controller="Order" asp-action="ShipOrder" method="post" class="mb-2">
                                <input type="hidden" name="id" value="@Model.OrderHeader.Id" />
                                <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold py-2 shadow-sm">
                                    Kirim Barang
                                </button>
                            </form>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>