@model IEnumerable<TokoSaya.Models.OrderHeader>

@{
    ViewData["Title"] = "Riwayat Pesanan";
}

<div class="container py-5">
    <h2 class="fw-bold mb-4">Riwayat Pesanan Anda</h2>

    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>ID Pesanan</th>
                    <th>Tanggal</th>
                    <th>Total Harga</th>
                    <th>Status Pesanan</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var item in Model)
                {
                    <tr>
                        <td>@(item.Id)</td>
                        <td>@(item.OrderDate.ToString("dd/MM/yyyy"))</td>
                        <td>Rp @(item.OrderTotal.ToString("N0"))</td>
                        <td>@(item.OrderStatus)</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@(item.Id)" class="btn btn-info btn-sm">Detail</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>