@model TokoSaya.ViewModels.ProductVM

@{
    ViewData["Title"] = "Create Product";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-11">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header border-0 text-white py-4 px-4"
                     style="background: linear-gradient(135deg, #0d6efd, #3b82f6);">
                    <h2 class="fw-bold mb-1">Tambah Produk</h2>
                    <p class="mb-0 text-white-50">Masukkan informasi produk baru dengan lengkap</p>
                </div>

                <div class="card-body p-4 p-lg-5 bg-light">
                    <form method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="All" class="text-danger mb-4"></div>

                        <div class="row g-4">
                            <div class="col-lg-8">
                                <div class="card border-0 shadow-sm rounded-4 h-100">
                                    <div class="card-body p-4">
                                        <h5 class="fw-bold mb-4">Informasi Produk</h5>

                                        <div class="mb-4">
                                            <label asp-for="Product.Name" class="form-label fw-semibold"></label>
                                            <input asp-for="Product.Name" class="form-control form-control-lg rounded-3"
                                                   placeholder="Masukkan nama produk" />
                                            <span asp-validation-for="Product.Name" class="text-danger small"></span>
                                        </div>

                                        <div class="mb-4">
                                            <label asp-for="Product.Description" class="form-label fw-semibold"></label>
                                            <textarea asp-for="Product.Description" class="form-control rounded-3"
                                                      rows="6" placeholder="Masukkan deskripsi produk"></textarea>
                                            <span asp-validation-for="Product.Description"
                                                  class="text-danger small"></span>
                                        </div>

                                        <div class="mb-4">
                                            <label asp-for="Product.Price" class="form-label fw-semibold"></label>
                                            <input asp-for="Product.Price"
                                                   class="form-control form-control-lg rounded-3"
                                                   placeholder="Masukkan harga produk" />
                                            <span asp-validation-for="Product.Price" class="text-danger small"></span>
                                        </div>

                                        <div class="mb-4">
                                            <label asp-for="Product.CategoryId" class="form-label fw-semibold"></label>
                                            <select asp-for="Product.CategoryId" asp-items="@Model.CategoryList"
                                                    class="form-select form-select-lg rounded-3">
                                                <option disabled selected>--Pilih Kategori--</option>
                                            </select>
                                            <span asp-validation-for="Product.CategoryId"
                                                  class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4">
                                <div class="card border-0 shadow-sm rounded-4">
                                    <div class="card-body p-4">
                                        <h5 class="fw-bold mb-4">Gambar Produk</h5>

                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Upload Gambar</label>
                                            <input type="file" name="file" class="form-control" accept="image/*" />
                                        </div>

                                        <div class="form-text">
                                            Pastikan nama parameter file adalah <strong>file</strong> agar bisa
                                            ditangkap oleh controller.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-4 flex-wrap">
                            <button type="submit"
                                    class="btn btn-primary btn-lg rounded-pill px-4 fw-semibold shadow-sm">
                                Simpan Produk
                            </button>
                            <a asp-controller="Product" asp-action="Index"
                                   class="btn btn-outline-secondary btn-lg rounded-pill px-4 fw-semibold">
                                Kembali
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}